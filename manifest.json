{
  "name": "ColumnCopy Pro",
  "version": "2.0.0",
  "manifest_version": 3,
  "description": "Copy table columns instantly. Easily copy columns, entire tables, export to CSV/JSON, pin columns, view copy history, and more.",
  "homepage_url": "https://github.com/jamesandres/ColumnCopy",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/bg/background.js"
  },

  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },

  "permissions": [
    "clipboardWrite",
    "contextMenus",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "file://*/*",
    "http://*/*",
    "https://*/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "file://*/*",
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "js/jquery/jquery.js",
        "js/jquery.hotkeys/jquery.hotkeys.js",
        "src/inject/inject.js"
      ],
      "css": [
        "src/inject/inject.css"
      ]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
